# Kopieer dit bestand naar canvas.env en vul je eigen waarden in.
# canvas.env wordt NIET meegecommit naar git (staat in .gitignore).
# Op Render.com stel je deze waarden in via het Environment-dashboard.

# De geheime sleutel die je hebt aangemaakt in je Canvas instellingen
# (Canvas → Account → Instellingen → + Nieuw toegangstoken)
CANVAS_API_TOKEN=jouw_canvas_api_token_hier

# De basis-URL van je Canvas-omgeving (zonder /courses/... aan het einde)
CANVAS_BASE_URL=https://canvas.hu.nl

# Het cursusnummer (te vinden in de URL van de cursuspagina)
CANVAS_COURSE_ID=50289
